---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base title="404 — BananaLabs">
  <Nav />

  <section style="flex:1;display:flex;align-items:center;justify-content:center;text-align:center;padding:120px 24px 80px;">
    <div>
      <h1 style="font-size:72px;font-weight:800;letter-spacing:-2px;color:var(--dim);margin-bottom:8px;">404</h1>
      <p style="font-size:18px;color:var(--muted);margin-bottom:12px;">This route doesn't resolve to anything.</p>
      <p style="font-size:14px;color:var(--muted);margin-bottom:32px;opacity:.6;">No container, no endpoint, no page. Just a banana peel on the floor.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a class="btn btn-primary" href="/">Back to the Stack</a>
        <a class="btn btn-secondary" href="https://github.com/BananaLabs-OSS">Browse on GitHub</a>
      </div>
    </div>
  </section>

  <Footer />
</Base>
